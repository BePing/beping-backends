{
  "name": "tabt-rest",
  "version": "4.8.5",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.15.1",
  "main": "dist/main.js",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build:tabt-rest": "nest build tabt-rest",
    "build:app-notifications": "nest build app-notifications",
    "build:data-aftt-importer": "nest build data-aftt-importer",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:tabt-rest": "node dist/apps/tabt-rest/main",
    "start:dev:data-aftt-importer": "nest start data-aftt-importer --watch",
    "start:dev:tabt-rest": "nest start tabt-rest --watch",
    "start:dev:app-notifications": "nest start app-notifications --watch",
    "start:debug:tabt-rest": "nest start tabt-rest --debug --watch",
    "start:prod:tabt-rest": "node dist/apps/tabt-rest/main",
    "start:prod:data-aftt-importer": "node dist/apps/data-aftt-importer/main",
    "start:prod:app-notifications": "node dist/apps/app-notifications/main",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "npm test -- --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config test-e2e/jest-e2e.json",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@keyv/redis": "^5.1.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/microservices": "^11.1.28",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@xmldom/xmldom": "0.9.10",
    "axios": "1.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.9",
    "cache-manager": "^7.2.9",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "compression": "1.8.1",
    "date-fns": "^4.4.0",
    "firebase-admin": "^14.2.0",
    "form-data": "4.0.6",
    "he": "1.2.0",
    "helmet": "8.3.0",
    "ioredis": "5.11.1",
    "jsdom": "^29.1.1",
    "keyv": "^5.6.0",
    "lodash": "4.18.1",
    "lunr": "2.3.9",
    "nestjs-pino": "4.6.1",
    "openai": "^6.48.0",
    "passport": "0.7.0",
    "passport-http": "0.3.0",
    "pg": "8.22.0",
    "pg-copy-streams": "^7.0.0",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "posthog-node": "^5.46.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "0.2.2",
    "response-time": "2.3.4",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "soap": "1.10.0",
    "socks-proxy-agent": "^10.1.0",
    "swagger-ui-express": "5.0.1",
    "user-agents": "2.1.128",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@schematics/angular": "22.0.7",
    "@types/compression": "1.8.1",
    "@types/continuation-local-storage": "3.2.7",
    "@types/express": "5.0.6",
    "@types/he": "1.2.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "4.17.24",
    "@types/lunr": "2.3.7",
    "@types/node": "24.13.3",
    "@types/response-time": "2.3.9",
    "@types/supertest": "7.2.1",
    "@types/user-agents": "1.0.4",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "9.1.7",
    "jest": "^30.4.2",
    "prettier": "3.9.6",
    "prisma": "^7.9.0",
    "rimraf": "6.1.3",
    "supertest": "7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".spec.ts$",
    "moduleNameMapper": {
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src$1"
    },
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(socks-proxy-agent|socks|agent-base|ip-address)/)"
    ],
    "coveragePathIgnorePatterns": [
      ".dto.ts",
      "entity",
      ".contract.ts",
      ".constants.ts",
      ".decorator.ts",
      "generated/prisma"
    ],
    "collectCoverageFrom": [
      "apps/**/*.ts",
      "libs/**/*.ts",
      "!**/*.spec.ts",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/*.dto.ts",
      "!**/entity/**",
      "!**/*.contract.ts",
      "!**/*.constants.ts",
      "!**/*.decorator.ts",
      "!libs/common/src/generated/**"
    ],
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "lines": 49,
        "statements": 49,
        "functions": 46,
        "branches": 42
      }
    },
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "coverageReporters": [
      "json",
      "json-summary",
      "lcov",
      "text",
      "text-summary"
    ],
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ]
  }
}
