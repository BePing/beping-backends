# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
DATABASE_URL=your_supabase_connection_string
DIRECT_URL=your_supabase_direct_connection_string
SHADOW_DATABASE_URL=your_local_shadow_database_connection_string

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=replace_with_a_strong_password
REDIS_TLS=false
# REDIS_URL=redis://:password@localhost:6379

# PostgreSQL connection pool (per process)
DB_POOL_MAX=5
DB_CONNECT_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_MAX_LIFETIME_SECONDS=300

# API Configuration
NODE_ENV=development
PORT=3050
API_PREFIX=api
STATIC_PREFIX=static
CURRENT_SEASON=24
THROTTLE_TTL=60000
THROTTLE_LIMIT=300
# Number of trusted reverse-proxy hops (production defaults to 1).
TRUST_PROXY_HOPS=1

# Internal Prometheus endpoint (do not publish through the public proxy)
METRICS_HOST=0.0.0.0
METRICS_PORT=9464

# Internal Prometheus endpoint (do not publish through the public proxy)
METRICS_HOST=0.0.0.0
METRICS_PORT=9464

# External Services
AFTT_WSDL=https://api.aftt.be/?wsdl
VTLL_WSDL=https://api.vttl.be/?wsdl
AFTT_HEAD2HEAD_TIMEOUT_MS=5000
AFTT_MATCH_DETAILS_TIMEOUT_MS=5000
AFTT_DATA_BASE_URL=https://data.aftt.be
AFTT_DATA_USERNAME=your_username
AFTT_DATA_PASSWORD=your_password
MEMBER_BATCH_SIZE=500
MEMBER_POINTS_BATCH_SIZE=500
RESULTS_BATCH_SIZE=500
IMPORT_BATCH_COOLDOWN_MS=100

# Proxy Configuration
USE_SOCKS_PROXY=false
SOCKS_PROXY_HOST=torproxy
SOCKS_PROXY_PORT=9050

# Notification Settings
BEPING_NOTIFICATION_URL=http://localhost:3000/
BEPING_NOTIFICATION_CONSUMER_KEY=your_consumer_key
BEPING_NOTIFICATION_CONSUMER_SECRET=your_consumer_secret

# Notifications service
FIREBASE_SERVICE_ACCOUNT_KEY=your_service_account_json
FIREBASE_APP_ID=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Importer throttling
SYNC_MEMBERS_ON_START=false
SYNC_RESULTS_ON_START=false
RESULTS_BATCH_SIZE=100
RESULTS_STAGE_CHUNK_SIZE=2000
IMPORT_BATCH_COOLDOWN_MS=750
IMPORT_API_READINESS_URL=https://api-v2.beping.be/v1/health/ready
IMPORT_API_HEALTH_TIMEOUT_MS=2000
IMPORT_API_MAX_LATENCY_MS=600
IMPORT_PRESSURE_PAUSE_MS=5000
IMPORT_PRESSURE_MAX_ATTEMPTS=120
IMPORT_STATEMENT_TIMEOUT_MS=300000
IMPORT_LOCK_TIMEOUT_MS=2000

# Captain Mode
CAPTAIN_JWT_SECRET=change_me_captain_access_secret
CAPTAIN_JWT_REFRESH_SECRET=change_me_captain_refresh_secret
# Base URL used to build public convocation links (player web view)
PUBLIC_BASE_URL=http://localhost:3050
# Backend-to-backend call to app-notifications (Basic auth APIConsumer)
NOTIFICATIONS_API_URL=http://localhost:3000
NOTIFICATIONS_API_USER=your_api_consumer_app
NOTIFICATIONS_API_PASSWORD=your_api_consumer_password
