// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
  provider     = "prisma-client"
  output       = "../libs/common/src/generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id             Int
  licence        Int
  playerCategory PlayerCategory
  firstname      String
  lastname       String
  email          String?
  ranking        String
  club           String
  category       String
  worldRanking   Int
  nationality    String

  pointsHistory     NumericPoints[]
  results           IndividualResult[] @relation("member")
  resultsAsOpponent IndividualResult[] @relation("memberopponent")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@id([id, licence])
  @@index([licence, playerCategory], name: "idx_member_licence_category")
  @@index([playerCategory, ranking], name: "idx_member_category_ranking")
  @@index([club, playerCategory], name: "idx_member_club_category")
}

enum PlayerCategory {
  SENIOR_MEN
  SENIOR_WOMEN
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model NumericPoints {
  memberId                Int
  memberLicence           Int
  date                    DateTime @default(now()) @db.Date
  member                  Member   @relation(fields: [memberId, memberLicence], references: [id, licence])
  points                  Float
  ranking                 Int?
  rankingWI               Int?
  rankingLetterEstimation String?

  @@id([memberId, memberLicence, date])
  @@index([date])
  @@index([memberLicence, date], name: "idx_numeric_points_licence_date")
}

model Competition {
  id          String             @id
  name        String
  type        CompetitionType
  coefficient Int
  results     IndividualResult[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model IndividualResult {
  id                    Int
  date                  DateTime       @default(now()) @db.Date
  playerCategory        PlayerCategory
  memberId              Int
  memberLicence         Int
  opponentId            Int
  opponentLicence       Int
  opponentRanking       String         @db.VarChar(4)
  memberRanking         String         @db.VarChar(4)
  memberPoints          Decimal?       @db.Decimal(6, 2)
  opponentPoints        Decimal?       @db.Decimal(6, 2)
  result                Result
  score                 String         @db.VarChar(3)
  competitionId         String
  competition           Competition    @relation(fields: [competitionId], references: [id])
  diffPoints            Decimal        @db.Decimal(6, 2)
  pointsToAdd           Int            @db.SmallInt
  looseFactor           Decimal        @db.Decimal(3, 2)
  definitivePointsToAdd Decimal        @db.Decimal(6, 2)
  member                Member         @relation("member", fields: [memberId, memberLicence], references: [id, licence])
  memberOpponent        Member         @relation("memberopponent", fields: [opponentId, opponentLicence], references: [id, licence])
  createdAt             DateTime       @default(now())

  @@id([id, playerCategory])
  @@index([date])
  @@index([competitionId])
  @@index([memberId, memberLicence], name: "idx_individual_result_member_identity")
  @@index([memberLicence, playerCategory, date], name: "idx_individual_result_licence_category_date")
}

enum CompetitionType {
  TOURNAMENT
  CHAMPIONSHIP
}

enum Result {
  VICTORY
  DEFEAT
}

model APIConsumer {
  id        Int      @id @default(autoincrement())
  app       String   @unique
  password  String
  updatedAt DateTime @updatedAt
}

model MobileNotificationSent {
  id               String           @id
  createdAt        DateTime         @default(now())
  sent             Boolean
  messageIds       String[]
  notificationType NotificationType
}

enum ImportType {
  MEMBER
  RESULT
}

model DataImport {
  id               Int            @id @default(autoincrement())
  type             ImportType
  playerCategory   PlayerCategory
  importedAt       DateTime       @default(now())
  hash             String // Store hashes of each line to detect changes
  fileDate         DateTime? // Date from the first line of the file (ISO-8601 format)
  linesProcessed   Int? // Number of lines processed (excluding header)
  linesAdded       Int? // Number of new records added
  linesUpdated     Int? // Number of existing records updated
  processingTimeMs Int? // Processing time in milliseconds

  @@index([type, playerCategory, importedAt])
  @@index([type, playerCategory, fileDate])
}

enum NotificationType {
  MATCH
  RANKING
  CUSTOM
  CAPTAIN_AVAILABILITY_REQUEST
  CAPTAIN_CONVOCATION
  CAPTAIN_LINEUP_REMINDER
}

model DeviceSubscription {
  id                 String              @id @default(cuid())
  userId             String? // Optional user ID for authenticated users
  deviceToken        String              @unique
  platform           DevicePlatform
  appVersion         String?
  locale             String              @default("fr")
  active             Boolean             @default(true)
  notificationTypes  NotificationType[]
  metadata           Json? // Additional device/user metadata
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastUsed           DateTime            @default(now())
  notificationLogs   NotificationLog[]
  topicSubscriptions TopicSubscription[]

  @@index([userId])
  @@index([active])
  @@index([platform])
}

model TopicSubscription {
  id                   String             @id @default(cuid())
  topic                String
  deviceSubscriptionId String
  deviceSubscription   DeviceSubscription @relation(fields: [deviceSubscriptionId], references: [id], onDelete: Cascade)
  createdAt            DateTime           @default(now())

  @@unique([deviceSubscriptionId, topic])
  @@index([topic])
}

model NotificationLog {
  id                   String              @id @default(cuid())
  deviceSubscriptionId String?
  notificationType     NotificationType
  title                String
  body                 String
  data                 Json? // Additional payload data
  fcmMessageId         String? // FCM response message ID
  status               NotificationStatus
  errorMessage         String?
  sentAt               DateTime            @default(now())
  deviceSubscription   DeviceSubscription? @relation(fields: [deviceSubscriptionId], references: [id], onDelete: SetNull)

  @@index([notificationType])
  @@index([status])
  @@index([sentAt])
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

enum NotificationOutboxType {
  PLAYER_RANKING_UPDATED
  RESULT_UPDATED
}

enum NotificationOutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

model NotificationOutbox {
  id               String                   @id @default(cuid())
  type             NotificationOutboxType
  deduplicationKey String                   @unique
  payload          Json
  status           NotificationOutboxStatus @default(PENDING)
  attempts         Int                      @default(0)
  availableAt      DateTime                 @default(now())
  processedAt      DateTime?
  lastError        String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([status, availableAt])
  @@index([type, createdAt])
}

// ---------------------------------------------------------------------------
// Captain Mode
// New user-generated domains for the "Mode Capitaine" module. Additive only.
// Federation force-list data is NOT duplicated here; it is derived from TabT at
// request time and snapshotted onto Lineup.forceSnapshot at validation time.
// ---------------------------------------------------------------------------

enum AvailabilityStatus {
  PRESENT
  ABSENT
  PENDING
}

enum ResponseSource {
  PLAYER
  CAPTAIN_OVERRIDE
}

enum LineupStatus {
  A_FAIRE
  BROUILLON
  VALIDEE
}

enum SlotRole {
  TITULAIRE
  BANC
  RENFORT_MONTANT
}

enum ConvocationStatus {
  CONFIRMED
  DECLINED
  PENDING
}

/// A verified AFTT member authorised to manage his club's teams.
/// AFTT credentials are never persisted; only the verified identity is stored.
model CaptainAccount {
  id             String   @id @default(cuid())
  uniqueIndex    Int      @unique
  clubIndex      String
  firstName      String?
  lastName       String?
  ranking        String?
  lastVerifiedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clubIndex])
}

model AvailabilityPoll {
  id            String                 @id @default(cuid())
  matchUniqueId Int                    @unique
  teamId        String
  clubIndex     String
  createdBy     Int
  responses     AvailabilityResponse[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([clubIndex])
  @@index([teamId])
}

model AvailabilityResponse {
  id          String             @id @default(cuid())
  pollId      String
  poll        AvailabilityPoll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  uniqueIndex Int
  status      AvailabilityStatus @default(PENDING)
  note        String?
  source      ResponseSource     @default(PLAYER)
  respondedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([pollId, uniqueIndex])
  @@index([uniqueIndex])
}

model Lineup {
  id                    String       @id @default(cuid())
  matchUniqueId         Int          @unique
  teamId                String
  clubIndex             String
  status                LineupStatus @default(A_FAIRE)
  forceSnapshot         Json?
  validation            Json?
  overrideJustification String?
  validatedAt           DateTime?
  createdBy             Int
  slots                 LineupSlot[]
  convocation           Convocation?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([clubIndex])
  @@index([teamId])
}

model LineupSlot {
  id          String   @id @default(cuid())
  lineupId    String
  lineup      Lineup   @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  uniqueIndex Int
  orderPos    Int // 1..4 titulaires, >100 banc
  role        SlotRole @default(TITULAIRE)
  createdAt   DateTime @default(now())

  @@unique([lineupId, uniqueIndex])
  @@index([lineupId])
}

model Convocation {
  id            String                @id @default(cuid())
  lineupId      String                @unique
  lineup        Lineup                @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  matchUniqueId Int                   @unique
  message       String
  meetingTime   String?
  venue         String?
  publicToken   String                @unique
  sentBy        Int
  responses     ConvocationResponse[]
  sentAt        DateTime              @default(now())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model ConvocationResponse {
  id            String            @id @default(cuid())
  convocationId String
  convocation   Convocation       @relation(fields: [convocationId], references: [id], onDelete: Cascade)
  uniqueIndex   Int
  status        ConvocationStatus @default(PENDING)
  source        ResponseSource    @default(PLAYER)
  respondedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([convocationId, uniqueIndex])
  @@index([uniqueIndex])
}
