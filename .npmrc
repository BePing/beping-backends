# pnpm: flat node_modules (npm-like) so webpack externals + cross-stage Docker copies work
node-linker=hoisted
# mirror the previous npm --legacy-peer-deps leniency:
# don't error on peer mismatches, and don't auto-install (optional) peers —
# auto-installing pulled the whole prisma CLI into prod via @prisma/client's optional peer.
strict-peer-dependencies=false
auto-install-peers=false
# don't run an implicit `pnpm install` before every `pnpm run` (CI/Docker install explicitly)
verify-deps-before-run=false
