{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug NestJS (tabt-rest)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
            "args": ["start", "tabt-rest", "--watch"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "NODE_OPTIONS": ""
            }
        },
        {
            "name": "Debug NestJS (data-aftt-importer)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
            "args": ["start", "data-aftt-importer", "--watch"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "NODE_OPTIONS": ""
            }
        },
        {
            "name": "Debug NestJS (app-notifications)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
            "args": ["start", "app-notifications", "--watch"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "NODE_OPTIONS": ""
            }
        }
    ]
}
